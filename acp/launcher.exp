#!/usr/bin/env expect -f
# Launch a persistent claude --channels session for the ACP session pool.
#
# Parameterized via environment variables (injected by session_pool.ts):
#   HERMES_CHANNEL_SOCKET   Socket path for the hermes-channel plugin to bind.
#                           Propagates to the plugin bun child via parent env
#                           (voie a — proven in spike 2026-06-14: no --strict-mcp-config).
#   HERMES_SESSION_NAME     The --name for the claude process (claude_hermes_<hash8>).
#                           Scoped per session_key — used for targeted kill on eviction.
#   HERMES_SESSION_CWD      Working directory for the claude session.
#
# PTY is required so claude can receive the dev-channels TUI confirmation.
# Two blind Enters dismiss the TUI prompt (no-op if not shown).
#
# NEVER use --strict-mcp-config: it suppresses the hermes-channel plugin entirely.

set timeout -1
log_user 1

# Resolve parameters from environment, with safe defaults.
# HERMES_CHANNEL_SOCKET does NOT need to be read here: expect inherits the full
# parent env, and the spawn'd claude process inherits it from expect. The
# hermes-channel plugin bun child then inherits it from claude (voie a, proven
# in spike 2026-06-14). No --strict-mcp-config so the plugin actually starts.
set session_name [expr { [info exists env(HERMES_SESSION_NAME)] ? $env(HERMES_SESSION_NAME) : "claude_hermes_acp" }]
set session_cwd [expr { [info exists env(HERMES_SESSION_CWD)] ? $env(HERMES_SESSION_CWD) : [pwd] }]
# Custom settings file (HERMES_CLAUDE_SETTINGS_FILE, same env var as claude_daemon):
# a controlled allow-list + only the hermes MCP, EXCLUDING the user's private
# plugins/connectors (context7, claude.ai Gmail/Drive/Notes...). Isolates the
# session's toolset from ~/.claude without touching the account/HOME.
set settings_file [expr { [info exists env(HERMES_CLAUDE_SETTINGS_FILE)] ? $env(HERMES_CLAUDE_SETTINGS_FILE) : "" }]

cd $session_cwd

if {$settings_file ne ""} {
    spawn /Users/guillaume/.local/bin/claude \
        --dangerously-load-development-channels plugin:hermes-channel@claude-channels-hermes \
        --name $session_name \
        --permission-mode auto \
        --model haiku \
        --setting-sources project,local \
        --settings $settings_file \
        --allowedTools "mcp__plugin_hermes-channel_hermes-channel__* Read"
} else {
    spawn /Users/guillaume/.local/bin/claude \
        --dangerously-load-development-channels plugin:hermes-channel@claude-channels-hermes \
        --name $session_name \
        --permission-mode auto \
        --model haiku \
        --allowedTools "mcp__plugin_hermes-channel_hermes-channel__* Read"
}

# Dismiss the dev-channels TUI confirmation by matching the prompt as soon as it
# appears (~725ms) instead of two blind sleeps (4s+3s). Spike 2026-06-15:
# spawn->socket-ready ~7.5s -> ~1.1s (-85%). The timeouts are safety nets: if the
# TUI text changes and no pattern matches, we wait then continue (≈ one blind Enter).
set timeout 8
expect {
    -re {development|[Cc]onfirm|[Pp]roceed|trust|cancel} {
        send "\r"
        set timeout 5
        expect {
            -re {development|[Cc]onfirm|[Pp]roceed|trust|cancel} { send "\r" }
            timeout {}
            eof { exit 0 }
        }
    }
    timeout {}
    eof { exit 0 }
}
set timeout -1

expect eof
